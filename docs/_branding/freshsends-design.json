{
  "meta": {
    "name": "Fresh Sends Design System",
    "version": "1.0.0",
    "description": "Design tokens and brand guidelines derived from freshsends.com. Supports brand identity, typography, colors, and component styling for Fresh Sends digital products.",
    "lastUpdated": "2026-04-01",
    "source": "https://freshsends.com/",
    "targetAudience": "Fresh Sends marketing, design, and development teams"
  },
  "brand": {
    "name": "Fresh Sends",
    "shortName": "FreshSends",
    "website": "https://freshsends.com",
    "contact": {
      "phone": "+1-888-848-2924",
      "email": "hello@freshsends.com"
    },
    "tagline": "Fresh flowers delivered to your door",
    "social": {
      "tiktok": "@freshsends",
      "instagram": "@freshsends"
    },
    "territories": ["US", "Canada"],
    "logo": {
      "format": "SVG",
      "width": "120px",
      "mobileWidth": "100px",
      "primaryColor": "#1A1A1A"
    },
    "voice": {
      "personality": "Warm, modern, approachable. Feels like a friend who sends great flowers — not a corporate florist.",
      "tone": "Casual-professional, upbeat, confident. Short punchy copy with playful serif italics for emphasis.",
      "avoid": "Overly formal language; generic floral cliches; cluttered layouts"
    }
  },
  "designPrinciples": {
    "core": [
      {
        "name": "Warm Minimalism",
        "description": "Clean layouts on a warm beige canvas. Let white space breathe. Every element earns its place."
      },
      {
        "name": "Playful Contrast",
        "description": "Pair bold sans-serif type with decorative serif italics. Mix pastel accents with near-black anchors."
      },
      {
        "name": "Tactile & Inviting",
        "description": "Design should feel like unwrapping a gift — soft colors, generous spacing, subtle motion."
      },
      {
        "name": "Mobile-First",
        "description": "All layouts scale gracefully. Touch targets, readable type, and single-column flows on small screens."
      }
    ]
  },
  "colors": {
    "philosophy": "A warm, neutral base (beige) with a vibrant multicolor accent palette. Black anchors the typography. Pastels and brights are used sparingly for highlights, badges, and seasonal campaigns.",
    "primary": {
      "black": {
        "hex": "#1A1A1A",
        "rgb": "26, 26, 26",
        "usage": "Primary text, borders, buttons, logo"
      },
      "beige": {
        "hex": "#FAF7F0",
        "rgb": "250, 247, 240",
        "usage": "Primary background, page canvas"
      }
    },
    "accent": {
      "red": {
        "hex": "#EF5331",
        "rgb": "239, 83, 49",
        "usage": "Primary call-to-action, alerts, seasonal emphasis"
      },
      "pink": {
        "hex": "#F4D3D6",
        "rgb": "244, 211, 214",
        "usage": "Secondary accent, announcement bars, soft highlights"
      },
      "yellow": {
        "hex": "#FFFF84",
        "rgb": "255, 255, 132",
        "usage": "Highlight, badges, attention markers"
      },
      "green": {
        "hex": "#D0E52A",
        "rgb": "208, 229, 42",
        "usage": "Fresh/natural accent, success states, seasonal"
      },
      "blue": {
        "hex": "#9DFFFF",
        "rgb": "157, 255, 255",
        "usage": "Cool accent, informational highlights"
      },
      "purple": {
        "hex": "#C4C3FF",
        "rgb": "196, 195, 255",
        "usage": "Decorative accent, badges, campaign elements"
      }
    },
